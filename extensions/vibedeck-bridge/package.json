{
  "name": "vibedeck-bridge-extension",
  "displayName": "VibeDeck Bridge",
  "description": "Localhost TCP bridge for VibeDeck and Cursor/VS Code extension hosts.",
  "version": "0.1.0",
  "private": true,
  "publisher": "fharena",
  "type": "module",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:vibedeckBridge.startServer",
    "onCommand:vibedeckBridge.stopServer",
    "onCommand:vibedeckBridge.showStatus",
    "onCommand:vibedeckBridge.validateCommands",
    "onCommand:vibedeckBridge.copyAgentEnv",
    "onCommand:vibedeckBridge.copySmokeCommand"
  ],
  "contributes": {
    "commands": [
      {
        "command": "vibedeckBridge.startServer",
        "title": "VibeDeck: Start Bridge"
      },
      {
        "command": "vibedeckBridge.stopServer",
        "title": "VibeDeck: Stop Bridge"
      },
      {
        "command": "vibedeckBridge.showStatus",
        "title": "VibeDeck: Show Bridge Status"
      },
      {
        "command": "vibedeckBridge.validateCommands",
        "title": "VibeDeck: Validate Commands"
      },
      {
        "command": "vibedeckBridge.copyAgentEnv",
        "title": "VibeDeck: Copy Agent Env"
      },
      {
        "command": "vibedeckBridge.copySmokeCommand",
        "title": "VibeDeck: Copy Smoke Command"
      }
    ],
    "configuration": {
      "title": "VibeDeck Bridge",
      "properties": {
        "vibedeckBridge.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Cursor/VS Code мӢӨн–ү мӢң localhost bridgeлҘј мһҗлҸҷмңјлЎң мӢңмһ‘н•©лӢҲлӢӨ."
        },
        "vibedeckBridge.mode": {
          "type": "string",
          "enum": [
            "command",
            "mock"
          ],
          "default": "command",
          "description": "command лӘЁл“ңлҠ” м„Өм •лҗң command IDлҘј нҳём¶ңн•ҳкі , мӢңмһ‘ м „м—җ command registryлҘј кІҖмҰқн•©лӢҲлӢӨ. mock лӘЁл“ңлҠ” м ҖмһҘмҶҢ fixture лЎңм§ҒмңјлЎң smoke testлҘј м ңкіөн•©лӢҲлӢӨ."
        },
        "vibedeckBridge.tcpHost": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "agentк°Җ л¶ҷмқ„ localhost bridge hostмһ…лӢҲлӢӨ. мҷёл¶Җ л…ём¶ңмқҖ к¶ҢмһҘн•ҳм§Җ м•ҠмҠөлӢҲлӢӨ."
        },
        "vibedeckBridge.tcpPort": {
          "type": "number",
          "default": 7797,
          "minimum": 1,
          "maximum": 65535,
          "description": "agentк°Җ л¶ҷмқ„ localhost bridge portмһ…лӢҲлӢӨ."
        },
        "vibedeckBridge.commands.submitTask": {
          "type": "string",
          "default": "vibedeck.submitTask",
          "description": "submitTaskлҘј мІҳлҰ¬н•  required command ID"
        },
        "vibedeckBridge.commands.getPatch": {
          "type": "string",
          "default": "vibedeck.getPatch",
          "description": "getPatchлҘј мІҳлҰ¬н•  required command ID"
        },
        "vibedeckBridge.commands.applyPatch": {
          "type": "string",
          "default": "vibedeck.applyPatch",
          "description": "applyPatchлҘј мІҳлҰ¬н•  required command ID"
        },
        "vibedeckBridge.commands.runProfile": {
          "type": "string",
          "default": "vibedeck.runProfile",
          "description": "runProfileмқ„ мІҳлҰ¬н•  required command ID"
        },
        "vibedeckBridge.commands.getRunResult": {
          "type": "string",
          "default": "vibedeck.getRunResult",
          "description": "getRunResultлҘј мІҳлҰ¬н•  required command ID"
        },
        "vibedeckBridge.commands.openLocation": {
          "type": "string",
          "default": "",
          "description": "openLocationмқ„ мІҳлҰ¬н•  optional command ID. л№„мӣҢл‘җл©ҙ кё°ліё editor open лҸҷмһ‘мқ„ мӮ¬мҡ©н•©лӢҲлӢӨ."
        },
        "vibedeckBridge.commands.getWorkspaceMetadata": {
          "type": "string",
          "default": "vibedeck.getWorkspaceMetadata",
          "description": "workspace metadataлҘј мқҪмқ„ optional command ID"
        },
        "vibedeckBridge.commands.getLatestTerminalError": {
          "type": "string",
          "default": "vibedeck.getLatestTerminalError",
          "description": "latest terminal errorлҘј мқҪмқ„ optional command ID"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vibedeck/cursor-bridge": "file:../../adapters/cursor-bridge"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/vscode": "^1.96.0",
    "typescript": "^5.9.3"
  }
}
